{
    "compilerOptions": {
        "target": "ESNext",
        "jsx": "react",
        "jsxFactory": "createMinecraftElement",
        "jsxFragmentFactory": "createMinecraftFragment",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "lib": [
            "ESNext",
            "DOM",
            "deno.ns"
        ]
    },
    "include": [
        "api/**/*.ts",
        "api/**/*.tsx",
        "api/FakeGlobals.d.ts",
    ]
}
